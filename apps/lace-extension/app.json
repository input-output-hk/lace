{
  "expo": {
    "name": "Lace Wallet",
    "slug": "lace-extension",
    "owner": "lace_io",
    "newArchEnabled": true,
    "version": "2.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "platforms": ["web"],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "3392c18a-1fec-44e6-b7e1-88f4ef096011"
      }
    },
    "experiments": {
      "baseUrl": "/expo"
    }
  }
}
