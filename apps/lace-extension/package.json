    "@lace-module/i18n": "*",
    "@lace-module/identity-center": "*",
    "@lace-module/migrate-multi-delegation": "*",
    "@lace-module/onboarding": "*",
    "@lace-module/posthog-client-extension": "*",
    "@lace-module/recovery-phrase-channel-extension": "*",
    "@lace-module/storage-extension": "*",
    "@lace-module/test-api": "*",
    "@lace-module/vault-in-memory": "*",
