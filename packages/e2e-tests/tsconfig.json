{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "ESNext",
    "target": "es2022",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "@wdio/globals/types",
      "@wdio/cucumber-framework",
      "expect-webdriverio",
      "chai",
      "@types/chai-sorted",
      "@types/chai-string",
      "@wdio/devtools-service",
      "wdio-intercept-service"
    ],
    "lib": ["es2022", "dom"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "rootDir": "../../"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node",
    "files": true
  },
  "include": ["."]
}
