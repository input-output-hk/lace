{
  "name": "lace-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "configs/*",
    "packages/module/*",
    "packages/contract/*",
    "packages/lib/*",
    "packages/sdk/*"
  ],
  "scripts": {
    "build": "nx run-many --target=build",
    "check": "run-s check:*",
    "check:format": "prettier --check .",
    "check:lint": "nx run-many --target=lint --max-warnings=0",
    "check:package-json": "eslint '**/package.json'",
    "check:types": "nx run-many --target=type-check-src,type-check-test",
    "dev": "nx run-many --target=dev",
    "docs:contract": "babel-node --config-file=./scripts/babel.config.json --extensions=\".ts,.tsx\"  scripts/generate-contract-diagram.ts",
    "docs:typedoc": "nx run-many --target=typedoc",
    "fix": "run-s fix:*",
    "fix:format": "prettier --cache --write .",
    "fix:lint": "npm run check:lint -- --fix",
    "postinstall": "node scripts/fix-wallet-sdk-abstractions.js && node scripts/check-lace-sdk-no-local-node-modules.mjs",
    "prepare": "husky",
    "react:devtools": "react-devtools",
    "reset": "nx reset",
    "storybook:mobile": "nx storybook lace-mobile-storybook -- --exact-port --port 6007",
    "storybook:mobile:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npm run storybook:mobile -- --ci\" \"wait-on tcp:6007 && npm run storybook:mobile:test -- --ci\"",
    "storybook:mobile:coverage": "STORYBOOK_COVERAGE=true concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npm run storybook:mobile -- --ci\" \"wait-on tcp:6007 && npm run storybook:mobile:test -- --ci\"",
    "storybook:mobile:perf-baseline": "DEBUG_STORYBOOK_PERF_TEST='false' STORYBOOK_PERF_TEST='true' STORYBOOK_PERF_TEST_IS_BASELINE='true' node --expose-gc ./scripts/lace-mobile-storybook-performance-tests/baseline-generator.mjs",
    "storybook:mobile:perf-test": "DEBUG_STORYBOOK_PERF_TEST='false' STORYBOOK_PERF_TEST='true' STORYBOOK_PERF_TEST_IS_BASELINE='false' node --expose-gc ./scripts/lace-mobile-storybook-performance-tests/compare-performance.mjs",
    "storybook:mobile:test": "DEBUG_STORYBOOK_PERF_TEST='false' STORYBOOK_PERF_TEST='false' STORYBOOK_PERF_TEST_IS_BASELINE='false' nx test-storybook lace-mobile-storybook --skip-nx-cache -- --url http://127.0.0.1:6007 --maxWorkers=1",
    "test": "nx run-many --target=test"
  },
  "lint-staged": {
    "package.json": "eslint --fix",
    "*.{js,cjs,mjs,ts,tsx,json,html,md,yml,yaml,css,scss}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "libsodium-sumo": "0.7.10",
    "libsodium-wrappers-sumo": "0.7.10",
