{
  "name": "lace-extension",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "NODE_ENV=production run-s prepare:expo-env build:ui build:app build:sw",
    "build:app": "webpack -c webpack/prod/app.webpack.config.js",
    "build:dev": "run-s prepare:expo-env build:dev:ui build:dev:app build:dev:sw",
    "build:dev:app": "webpack -c webpack/dev/app.webpack.config.js",
    "build:dev:sw": "webpack -c webpack/dev/serviceworker.webpack.config.js",
    "build:dev:ui": "expo export --no-minify --dump-sourcemap --output-dir dist/expo",
    "build:sw": "webpack -c webpack/prod/serviceworker.webpack.config.js",
    "build:ui": "expo export --clear --output-dir dist/expo --dump-sourcemap && npm run upload:ui",
    "dev": "NODE_ENV=development run-p prepare:expo-env dev:ui dev:app dev:sw redux-devtools",
    "dev:app": "npm run build:dev:app -- --watch",
    "dev:sw": "npm run build:dev:sw -- --watch",
    "dev:ui": "chokidar --initial \"metro.config.js\" \"src/**/*.{ts,tsx}\" \"../../packages/**/*.{ts,tsx}\" -c \"npm run build:dev:ui\"",
    "prepare:expo-env": "tsx scripts/prepare-expo-env.ts webpack .",
    "react-devtools": "react-devtools",
    "redux-devtools": "tsx scripts/setup-redux-devtools.ts && npx redux-devtools --hostname=localhost --port=8000",
    "upload:ui": "bash scripts/upload-expo-sourcemaps.sh"
  },
  "dependencies": {
    "@emurgo/cardano-message-signing-browser": "^1.0.1",
    "@lace-contract/app": "*",
    "@lace-contract/authentication-prompt": "*",
    "@lace-contract/feature": "*",
    "@lace-contract/midnight-context": "*",
    "@lace-contract/module": "*",
    "@lace-contract/notification-center": "*",
    "@lace-contract/onboarding-v2": "*",
    "@lace-contract/send-flow": "*",
    "@lace-contract/sync": "*",
    "@lace-contract/tokens": "*",
    "@lace-contract/tx-executor": "*",
    "@lace-contract/views": "*",
    "@lace-contract/wallet-repo": "*",
    "@lace-lib/ui-toolkit": "*",
    "@lace-lib/util-render": "*",
    "@lace-lib/util-store": "*",
    "@lace-module/ada-handle": "*",
    "@lace-module/analytics-dev": "*",
    "@lace-module/analytics-posthog": "*",
    "@lace-module/app-activity-web": "*",
    "@lace-module/app-lock": "*",
    "@lace-module/app-mobile": "*",
    "@lace-module/authentication-prompt-ui-v2-extension": "*",
    "@lace-module/bitcoin-mempool-fee-market": "*",
    "@lace-module/bitcoin-provider-maestro": "*",
    "@lace-module/blockchain-bitcoin": "*",
    "@lace-module/blockchain-cardano": "*",
    "@lace-module/cardano-collateral-flow": "*",
    "@lace-module/cardano-provider-blockfrost": "*",
