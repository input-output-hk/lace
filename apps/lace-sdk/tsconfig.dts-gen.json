{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "outDir": "./dist/.dts-work",
    "rootDir": "../..",
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "../../packages/contract/*/src/**/*",
    "../../packages/lib/cardano-provider-core/src/**/*",
    "../../packages/lib/core/src/**/*",
    "../../packages/lib/crypto/src/**/*",
    "../../packages/lib/extension-messaging/src/**/*",
    "../../packages/lib/observability/src/**/*",
    "../../packages/lib/util/src/**/*",
    "../../packages/lib/util-hw/src/**/*",
    "../../packages/lib/util-provider/src/**/*",
    "../../packages/lib/util-redacted/src/**/*",
    "../../packages/lib/util-render/src/**/*",
    "../../packages/lib/util-store/src/**/*",
    "../../packages/lib/vendor/src/**/*",
    "../../packages/module/blockchain-cardano/src/sdk.ts",
    "../../packages/module/cardano-provider-blockfrost/src/sdk.ts",
    "../../packages/module/crypto-cardano-sdk/src/sdk.ts",
    "../../packages/module/feature-dev/src/sdk.ts",
    "../../packages/module/storage-in-memory/src/sdk.ts",
    "../../packages/module/swap-provider-steelswap/src/sdk.ts"
  ],
  "exclude": [
    "**/*.test.*",
    "**/test/**",
    "**/*.stories.*",
    "**/stories/**",
    "**/__mocks__/**"
  ]
}
