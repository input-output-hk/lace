{
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "rootDir": "./dist/.dts-work"
  },
  "include": [
    "dist/.dts-work/apps/lace-sdk/src/**/*",
    "dist/.dts-work/packages/**/*"
  ]
}
